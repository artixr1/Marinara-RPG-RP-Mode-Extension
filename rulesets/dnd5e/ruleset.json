  "skillProficiency": {
    "tiers": [
      {
        "code": "U",
        "label": "Untrained",
        "rollBonusFormula": "0"
      },
      {
        "code": "T",
        "label": "Trained",
        "rollBonusFormula": "{Proficiency Bonus}"
      },
      {
        "code": "E",
        "label": "Expertise",
        "rollBonusFormula": "2 * {Proficiency Bonus}"
      }
    ],
    "default": "U"
  },
  "derivedStats": [
    {
      "name": "Hit Points",
      "formula": "(class hit die avg) + CON_mod, per level",
      "renderAs": "bar",
      "aliases": [
        "hp",
        "HP",
        "hitPoints",
        "hitpoints"
      ]
    },
    {
      "name": "Armor Class",
      "formula": "10 + DEX_mod (or armor formula)",
      "renderAs": "value",
      "default": 10,
      "aliases": [
        "ac",
        "AC",
        "armorClass"
      ]
    },
    {
      "name": "Initiative",
      "formula": "DEX_mod",
      "renderAs": "value",
      "valueFormula": "{Dexterity_mod}",
      "rollFormula": "{Dexterity_mod}",
      "aliases": [
        "init",
        "initiative"
      ]
    },
    {
      "name": "Proficiency Bonus",
      "formula": "+2 at level 1-4, +3 at 5-8, +4 at 9-12, +5 at 13-16, +6 at 17-20",
      "renderAs": "value",
      "valueFormula": "2 + (({Level} - 1) / 4)",
      "aliases": [
        "prof",
        "proficiency",
        "proficiencyBonus",
        "PB"
      ]
    },
    {
      "name": "Speed",
      "formula": "Race base (typically 30 ft)",
      "renderAs": "value",
      "aliases": [
        "speed",
        "movement"
      ]
    },
    {
      "name": "Level",
      "formula": "Character level, 1-20.",
      "max": 20,
      "default": 1,
      "renderAs": "value",
      "aliases": [
        "level",
        "lvl",
        "LVL",
        "characterLevel"
      ]
    }
  ],
  "states": [],
  "diceTagFormat": {
    "template": "[dice: 1d20{+MOD}{+PROF} vs DC{DC} = {result}]",
    "example": "[dice: 1d20+3+2 vs DC15 = 17 success]"
  },
