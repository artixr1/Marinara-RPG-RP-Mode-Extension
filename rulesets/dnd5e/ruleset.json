  "conditions": [
    {
      "name": "Blinded",
      "description": "Cannot see; auto-fails sight checks. Attack rolls are at disadvantage and attacks against have advantage.",
      "imposesDisadvantageOn": [
        "attack"
      ]
    },
    {
      "name": "Charmed",
      "description": "Cannot attack the charmer or target them with harmful abilities. Charmer has advantage on social checks against you."
    },
    {
      "name": "Deafened",
      "description": "Cannot hear; auto-fails hearing checks."
    },
    {
      "name": "Frightened",
      "description": "Disadvantage on ability checks and attack rolls while source of fear is in line of sight. Cannot move closer to source.",
      "imposesDisadvantageOn": [
        "attack",
        "skill"
      ]
    },
    {
      "name": "Grappled",
      "description": "Speed becomes 0; ends if grappler is incapacitated."
    },
    {
      "name": "Incapacitated",
      "description": "Cannot take actions or reactions."
    },
    {
      "name": "Invisible",
      "description": "Heavily obscured for hiding. Attack rolls have advantage; attacks against have disadvantage.",
      "grantsAdvantageOn": [
        "attack"
      ]
    },
    {
      "name": "Paralyzed",
      "description": "Incapacitated; cannot move or speak. Auto-fails STR and DEX saves. Attacks against have advantage and crit on hit within 5 ft."
    },
    {
      "name": "Petrified",
      "description": "Transformed to stone; incapacitated; resistance to all damage; immune to poison and disease."
    },
    {
      "name": "Poisoned",
      "description": "Disadvantage on attack rolls and ability checks.",
      "imposesDisadvantageOn": [
        "attack",
        "skill"
      ]
    },
    {
      "name": "Prone",
      "description": "Disadvantage on attack rolls. Attackers within 5 ft have advantage; attackers further away have disadvantage.",
      "imposesDisadvantageOn": [
        "attack"
      ]
    },
    {
      "name": "Restrained",
      "description": "Speed becomes 0. Disadvantage on attack rolls and DEX saves. Attacks against have advantage.",
      "imposesDisadvantageOn": [
        "attack",
        "save"
      ]
    },
    {
      "name": "Stunned",
      "description": "Incapacitated; cannot move; can speak only falteringly. Auto-fails STR and DEX saves. Attacks against have advantage."
    },
    {
      "name": "Unconscious",
      "description": "Incapacitated; cannot move or speak; drops what it holds; falls prone. Auto-fails STR and DEX saves. Melee attacks within 5 ft crit on hit."
    },
    {
      "name": "Exhausted",
      "description": "Stack 1-6. Disadvantage on ability checks (level 1+); halved speed (level 2+); disadvantage on attacks and saves (level 3+); HP max halved (level 4+); speed reduced to 0 (level 5+); death (level 6).",
      "imposesDisadvantageOn": [
        "skill"
      ]
    }
  ]
