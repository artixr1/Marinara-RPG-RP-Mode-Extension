{
  "id": "dnd5e",
  "name": "Dungeons & Dragons 5th Edition",
  "version": "1.0.0",
  "edition": "5e (SRD 5.1)",
  "license": "CC-BY-4.0 (D&D 5.1 SRD), Wizards of the Coast",
  "summary": "The classic d20 system. One die, plus an attribute modifier, plus proficiency if trained, against a fixed Difficulty Class. Mirrors Marinara Engine's existing Game Mode default.",
  "dice": {
    "type": "d20",
    "notation": "1d20+MOD"
  },
  "resolution": {
    "mode": "single-roll",
    "modifierFormula": "1d20 + ability_mod + (proficient ? proficiency_bonus : 0)",
    "skillBonusFormula": "{linkedAttribute_mod} + {tierBonus}",
    "spellSaveDcFormula": "8 + {Proficiency Bonus} + {spellcastingAttribute_mod}",
    "attackProficiencyFormula": "{Proficiency Bonus}"
  },
  "difficulties": {
    "Very Easy": {
      "threshold": 5,
      "description": "Trivial; only roll if a fail is interesting."
    },
    "Easy": {
      "threshold": 10,
      "description": "An untrained adult can manage on a good day."
    },
    "Medium": {
      "threshold": 15,
      "description": "A trained character expects to succeed."
    },
    "Hard": {
      "threshold": 20,
      "description": "A trained character with a good attribute may still fail."
    },
    "Very Hard": {
      "threshold": 25,
      "description": "Possible only with high attribute and proficiency, or magic."
    },
    "Nearly Impossible": {
      "threshold": 30,
      "description": "Heroic. Stack every advantage."
    }
  },
  "attributes": [
    {
      "name": "Strength",
      "abbreviation": "STR",
      "min": 1,
      "max": 30,
      "default": 10,
      "description": "Raw physical power, athletic training, the extent to which you can exert raw physical force.",
      "modifierFormula": "({Score} - 10) / 2"
    },
    {
      "name": "Dexterity",
      "abbreviation": "DEX",
      "min": 1,
      "max": 30,
      "default": 10,
      "description": "Agility, reflexes, balance, poise.",
      "modifierFormula": "({Score} - 10) / 2"
    },
    {
      "name": "Constitution",
      "abbreviation": "CON",
      "min": 1,
      "max": 30,
      "default": 10,
      "description": "Health, stamina, vital force.",
      "modifierFormula": "({Score} - 10) / 2"
    },
    {
      "name": "Intelligence",
      "abbreviation": "INT",
      "min": 1,
      "max": 30,
      "default": 10,
      "description": "Mental acuity, accuracy of recall, ability to reason.",
      "modifierFormula": "({Score} - 10) / 2"
    },
    {
      "name": "Wisdom",
      "abbreviation": "WIS",
      "min": 1,
      "max": 30,
      "default": 10,
      "description": "Awareness, intuition, insight, attunement to surroundings.",
      "modifierFormula": "({Score} - 10) / 2"
    },
    {
      "name": "Charisma",
      "abbreviation": "CHA",
      "min": 1,
      "max": 30,
      "default": 10,
      "description": "Force of personality, persuasiveness, leadership.",
      "modifierFormula": "({Score} - 10) / 2"
    }
  ],
