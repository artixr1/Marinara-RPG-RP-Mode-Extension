{
  "id": "exalted3e",
  "name": "Exalted 3rd Edition",
  "version": "1.1.0",
  "edition": "Exalted 3rd Edition Core (2016, Onyx Path)",
  "license": "Original mechanics references; charm names belong to Onyx Path Publishing. No verbatim Onyx Path text reproduced.",
  "summary": "Storyteller-system d10 dice pools. Pool = Attribute + Ability. Successes on 7+. Tens double on PC/major-NPC rolls. Botch on a roll that shows zero successes AND at least one 1.",
  "commitmentModel": "mote",
  "dice": {
    "type": "d10",
    "notation": "Xd10 vs 7"
  },
  "resolution": {
    "mode": "dice-pool",
    "poolFormula": "Attribute + Ability (+ specialty +1, + stunt up to +2, + Charm dice)",
    "target": 7,
    "doubles": {
      "face": 10,
      "successes": 2
    },
    "botches": {
      "onFace": 1,
      "trigger": "any-on-zero-successes"
    }
  },
  "difficulties": {
    "Routine": {
      "threshold": 1,
      "description": "Trivial for a competent character. Often waived."
    },
    "Standard": {
      "threshold": 2,
      "description": "Default opposed baseline."
    },
    "Difficult": {
      "threshold": 3,
      "description": "Pushes a skilled mortal."
    },
    "Demanding": {
      "threshold": 4,
      "description": "Few mortals can do it reliably."
    },
    "Legendary": {
      "threshold": 5,
      "description": "Peak of mortal-scale achievement; songs are sung."
    },
    "Beyond Legendary": {
      "threshold": 7,
      "description": "Wyld navigation, First-Age relics, Essence > 5 territory."
    }
  },
