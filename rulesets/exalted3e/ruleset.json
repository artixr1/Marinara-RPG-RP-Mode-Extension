        "bashingSoak",
        "bSoak"
      ]
    },
    {
      "name": "Soak (Lethal)",
      "formula": "Stamina + armor L-soak (Exalts use FULL Stamina; mortals use Stamina/2 rounded down)",
      "renderAs": "value",
      "valueFormula": "{Stamina} + {bonuses:Lethal Soak}",
      "tooltipFormula": "{Stamina} + {bonuses:Lethal Soak}",
      "aliases": [
        "soakLethal",
        "lethalSoak",
        "lSoak"
      ]
    },
    {
      "name": "Hardness",
      "formula": "Highest equipped armor's Hardness rating + Charm/magic Hardness bonuses (set base manually; armor and Charms appear as +N suffix from item bonuses targeting \"Hardness\")",
      "renderAs": "value",
      "default": 0,
      "aliases": [
        "hardness"
      ]
    }
  ],
  "states": [
    {
      "name": "Anima Banner",
      "values": [
        {
          "label": "Suppressed",
          "description": "Anima banner is suppressed or unlit. No outward flare; caste mark dormant. Use when the Exalt has spent no Peripheral motes this action, is intentionally damping the banner (Charm or stunt), or is a non-Exalt who simply has no anima."
        },
        {
          "label": "Dim",
          "trigger": "0-4 Peripheral motes spent in one action; only the caste mark glints when motes are spent."
        },
        {
          "label": "Glowing",
          "trigger": "5-10 Peripheral motes spent in one action; faint nimbus, caste mark steady."
        },
        {
          "label": "Burning",
          "trigger": "11-15 Peripheral motes spent in one action; bright glow, surrounding flicker."
        },
        {
          "label": "Bonfire",
          "trigger": "16+ Peripheral motes spent in one action; massive radiance, illuminates the scene."
        },
        {
          "label": "Iconic",
          "trigger": "Sustained Bonfire or specific Charm triggers; full totemic spirit-shape."
        }
      ]
    },
    {
      "name": "Stunt Tier",
      "values": [
        {
          "label": "None",
          "description": "Plain action description."
        },
        {
          "label": "1-die",
          "description": "Vivid, environment-aware. Reward: +2 dice OR +1 to a static value."
        },
        {
          "label": "2-die",
          "description": "Genuinely creative, integrates fiction. Reward: +2 dice OR +2 static, plus 1 mote OR 1 Willpower."
        },
        {
          "label": "3-die",
          "description": "Spontaneous, table-applauds. Reward: +2 dice OR +3 static, plus 2 motes OR 2 Willpower (can exceed cap). Rare by GM design."
        }
      ]
    },
    {
      "name": "Sorcery Circle",
      "values": [
        {
          "label": "None",
          "description": "Has not yet learned any Sorcery (or is not a sorcerer)."
        },
        {
          "label": "Terrestrial",
          "description": "Emerald Circle. Open to Solars, Lunars, Sidereals, Dragon-Blooded, Liminals, and rare mortals. Foundation tier."
        },
        {
          "label": "Celestial",
          "description": "Sapphire Circle. Solars, Lunars, Sidereals only. Higher mysteries; cannot be learned without first mastering Terrestrial."
        },
        {
          "label": "Solar",
          "description": "Adamant Circle. Solar Exalted only. The peak of mortal sorcerous power; legends and rumors only since the Sun's Chosen disappeared."
        }
      ]
    },
    {
      "name": "Shaping Spell",
      "values": [
        {
          "label": "None",
          "description": "Not currently shaping a spell."
        },
        {
          "label": "Shaping",
          "description": "A spell is being shaped. The spell name should be tracked as a 'Shaping: <spell name>' condition; sorcerous motes accumulate in the Sorcerous Motes counter; 1 Willpower is committed up front and refunded only on successful cast."
        }
      ]
    },
    {
      "name": "Initiative",
      "values": [
        {
          "label": "Active",
          "description": "Initiative is at 1 or higher. The character is operating normally in combat \u2014 withering attacks add to their Initiative, decisive attacks may be declared, and standard Join Battle ordering applies."
        },
        {
          "label": "Crashed",
          "trigger": "Initiative drops to 0 or below as a result of withering damage or specific Charm effects.",
          "description": "Initiative crashed. The character cannot make decisive attacks until they reset to base, suffers Onslaught penalties more readily, and is the prime target for finishing decisive attacks. Reset to base Initiative occurs after 3 turns (or 5 if crashed below -5), at which point the Crash Recovery bonus applies and the character returns to Active."
        }
      ]
    }
  ],
