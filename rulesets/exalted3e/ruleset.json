      "aliases": [
        "resolve"
      ]
    },
    {
      "name": "Guile",
      "formula": "(Manipulation + Socialize) / 2, round up",
      "renderAs": "value",
      "valueFormula": "({Manipulation} + {Socialize} + 1) / 2",
      "aliases": [
        "guile"
      ]
    },
    {
      "name": "Join Battle",
      "formula": "Wits + Awareness (dice pool; on declare-attack first action)",
