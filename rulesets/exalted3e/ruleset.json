      "valueFormula": "{Wits} + {Awareness}",
      "aliases": [
        "joinBattle",
        "initiative"
      ]
    },
    {
      "name": "Soak (Natural)",
      "formula": "Stamina (Exalts use full Stamina; mortals halve, round down)",
