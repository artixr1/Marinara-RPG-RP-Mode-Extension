        {
          "id": "bashing",
          "label": "B",
          "severity": 0,
          "description": "Blunt or non-lethal. Heals quickly. Pushed to the right when worse damage stacks on top."
        },
        {
          "id": "lethal",
          "label": "L",
          "severity": 1,
          "description": "Edged or piercing. Slow to heal. Sits between bashing and aggravated."
        },
        {
          "id": "aggravated",
          "label": "A",
          "severity": 2,
          "description": "Soulsteel, fire, dragon-blood claws. Heals only with magical aid. Always leftmost in the damage stack."
        }
      ],
      "aliases": [
        "hp",
        "HP",
        "health",
        "health track",
        "healthTrack"
      ]
    },
    {
      "name": "Defense (Parry)",
      "formula": "(Dexterity + Melee) / 2, round up; armor and Charms apply",
      "renderAs": "value",
      "valueFormula": "({Dexterity} + {Melee} + 1) / 2",
      "aliases": [
        "parry",
        "parryDefense"
      ]
    },
    {
      "name": "Defense (Evasion)",
      "formula": "(Dexterity + Dodge) / 2, round up; armor penalty applies",
